)
library(dplyr)
library(ggplot2)
library(igraph)
library(pheatmap)
library(knitr)
library(nnet)
library(pscl)
load("~/Documents/GitHub/CustomersVisualBehavior/PreProcessedData.RData")
all_aois <- bind_rows(
lapply(
NetworkList,
function(x){
data.frame(
AOI = names(x$node_freq),
Visits = as.numeric(x$node_freq)
)
}
)
)
freq_tab <- all_aois %>%
group_by(AOI) %>%
summarise(
Visits = sum(Visits),
.groups = "drop"
) %>%
arrange(desc(Visits))
kable(
freq_tab,
digits = 0,
caption = "AOI visitation frequencies."
)
p1 <- ggplot(
freq_tab,
aes(
reorder(AOI, Visits),
Visits
)
)+
geom_col(
fill = "darkgreen"
)+
coord_flip()+
theme_minimal()+
labs(
x = "",
y = "Number of Visits"
)
print(p1)
ggsave(
"F2",
p1,
width = 8,
height = 6,
dpi = 600
)
ggsave(
filename = "F2.png",
p1,
width = 8,
height = 6,
dpi = 600
)
all_edges <- bind_rows(
lapply(
NetworkList,
function(x){
x$edges
}
)
)
agg_edges <- all_edges %>%
count(
from,
to,
name = "weight"
)
mat <- xtabs(
weight ~ from + to,
data = agg_edges
)
png(
"F2_Heatmap.png",
width = 5000,
height = 3500,
units = "px",
res = 600
)
