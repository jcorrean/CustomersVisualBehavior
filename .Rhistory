all_aois <- bind_rows(
lapply(NetworkList,
function(x){
data.frame(
AOI = names(x$node_freq),
Visits = as.numeric(x$node_freq)
)
})
)
freq_tab <- all_aois %>%
group_by(AOI) %>%
summarise(
Visits = sum(Visits)
) %>%
arrange(desc(Visits))
View(freq_tab)
knitr::kable(
freq_tab,
caption="AOI visitation frequencies."
)
ggplot(
freq_tab,
aes(
reorder(AOI,Visits),
Visits
)
)+
geom_col(fill="darkgreen")+
coord_flip()
ggplot(
freq_tab,
aes(
reorder(AOI,Visits),
Visits
)
)+
geom_col(fill="darkgreen")+
coord_flip()
