#########################################################
# MAPPING THE VISUAL JOURNEY
# RESULTS SCRIPT
#########################################################
library(dplyr)
library(ggplot2)
library(igraph)
library(pheatmap)
library(knitr)
library(nnet)
library(pscl)
#########################################################
# LOAD DATA
#########################################################
load("~/Documents/GitHub/CustomersVisualBehavior/PreProcessedData.RData")
#########################################################
# =======================================================
# RQ1
# WHAT INFORMATIONAL ELEMENTS OCCUPY CENTRAL POSITIONS?
# =======================================================
#########################################################
#########################################################
# AOI VISIT FREQUENCIES
#########################################################
all_aois <- bind_rows(
lapply(
NetworkList,
function(x){
data.frame(
AOI = names(x$node_freq),
Visits = as.numeric(x$node_freq)
)
}
)
)
freq_tab <- all_aois %>%
group_by(AOI) %>%
summarise(
Visits = sum(Visits),
.groups = "drop"
) %>%
arrange(desc(Visits))
#########################################################
# TABLE 1
#########################################################
kable(
freq_tab,
digits = 0,
caption = "AOI visitation frequencies."
)
#########################################################
# FIGURE 1
#########################################################
p1 <- ggplot(freq_tab, aes(reorder(AOI, Visits), Visits))+
geom_col(fill = "darkgreen")+
coord_flip()+
theme_minimal()+
labs(x = "", y = "Number of Visits")
print(p1)
ggsave(
filename = "F2.png",
p1,
width = 8,
height = 6,
dpi = 600
)
all_edges <- bind_rows(
lapply(
NetworkList,
function(x){
x$edges
}
)
)
agg_edges <- all_edges %>%
count(
from,
to,
name = "weight"
)
mat <- xtabs(
weight ~ from + to,
data = agg_edges
)
png(
"F3.png",
width = 5000,
height = 3500,
units = "px",
res = 600
)
pheatmap(
mat,
clustering_distance_rows = "euclidean",
clustering_distance_cols = "euclidean",
clustering_method = "ward.D2",
color = colorRampPalette(
c("white","darkgreen")
)(100),
main = "Hierarchical Clustering of AOI-to-AOI Transition Frequencies"
)
dev.off()
